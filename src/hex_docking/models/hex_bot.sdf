<?xml version="1.0"?>
<sdf version="1.8">
  <model name="hex_bot">
    <pose>0 0 0 0 0 0</pose>

    <link name="chassis">
      <pose>0 0 0.065 0 0 0</pose>

      <inertial>
        <mass>1.4</mass>
        <inertia>
          <ixx>0.014</ixx>
          <iyy>0.022</iyy>
          <izz>0.034</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="visual_body">
        <geometry>
          <polyline>
            <height>0.06</height>
            <point>0.18 0.00</point>
            <point>0.09 0.155</point>
            <point>-0.09 0.155</point>
            <point>-0.18 0.00</point>
            <point>-0.09 -0.155</point>
            <point>0.09 -0.155</point>
          </polyline>
        </geometry>
        <material>
          <ambient>0.20 0.20 0.25 1</ambient>
          <diffuse>0.25 0.25 0.30 1</diffuse>
          <specular>0.03 0.03 0.03 1</specular>
        </material>
      </visual>

      <visual name="front_marker">
        <pose>0.165 0 0.04 0 0 0</pose>
        <geometry>
          <box>
            <size>0.030 0.12 0.010</size>
          </box>
        </geometry>
        <material>
          <ambient>0.90 0.05 0.05 1</ambient>
          <diffuse>1.00 0.10 0.10 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>
    </link>

    <link name="left_front_wheel">
      <pose>0.09 0.165 0.05 1.5708 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00025</iyy>
          <izz>0.00025</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.03 0.03 0.03 1</specular>
        </material>
      </visual>
    </link>

    <link name="left_rear_wheel">
      <pose>-0.09 0.165 0.05 1.5708 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00025</iyy>
          <izz>0.00025</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.03 0.03 0.03 1</specular>
        </material>
      </visual>
    </link>

    <link name="right_front_wheel">
      <pose>0.09 -0.165 0.05 1.5708 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00025</iyy>
          <izz>0.00025</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.03 0.03 0.03 1</specular>
        </material>
      </visual>
    </link>

    <link name="right_rear_wheel">
      <pose>-0.09 -0.165 0.05 1.5708 0 0</pose>
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00025</iyy>
          <izz>0.00025</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.03 0.03 0.03 1</specular>
        </material>
      </visual>
    </link>

    <joint name="left_front_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_front_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.08</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="left_rear_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_rear_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.08</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="right_front_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_front_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.08</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="right_rear_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_rear_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.08</damping>
        </dynamics>
      </axis>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_front_wheel_joint</left_joint>
      <left_joint>left_rear_wheel_joint</left_joint>
      <right_joint>right_front_wheel_joint</right_joint>
      <right_joint>right_rear_wheel_joint</right_joint>
      <wheel_separation>0.33</wheel_separation>
      <wheel_radius>0.05</wheel_radius>
      <frame_id>odom</frame_id>
      <child_frame_id>chassis</child_frame_id>
      <odom_publish_frequency>10</odom_publish_frequency>
    </plugin>

  </model>
</sdf>
